# ─── Required ────────────────────────────────────────────
# Telegram bot token from @BotFather
BOT_TOKEN=

# Admin Telegram user ID
ADMIN_ID=

# Optional: comma-separated list if you want multiple admins
# ADMIN_IDS=123456789,987654321

# ─── Optional (manual top-up display) ────────────────────
# Easypaisa receiver number
PAYMENT_EASYPAISA=0300-XXXXXXX

# JazzCash receiver number
PAYMENT_JAZZCASH=0301-XXXXXXX

# Account holder name shown to users on manual top-up screen
PAYMENT_ACCOUNT_NAME=Pixel Verification
